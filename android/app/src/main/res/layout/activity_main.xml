<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nm_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ── Logo / Title ── -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/nm_accent"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textSize="12sp"
            android:textColor="@color/nm_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- ── Status Card ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/nm_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_starting"
                android:textColor="@color/nm_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvSSID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ssid_placeholder"
                android:textColor="@color/nm_text"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password_placeholder"
                android:textColor="@color/nm_text"
                android:textSize="15sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDashboardUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_placeholder"
                android:textColor="@color/nm_accent"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvRootStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/root_checking"
                android:textColor="@color/nm_secondary"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- ── Action Buttons ── -->
        <Button
            android:id="@+id/btnOpenDashboard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_open_dashboard"
            android:backgroundTint="@color/nm_accent"
            android:textColor="@color/nm_background"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_stop_service"
            android:backgroundTint="@color/nm_card"
            android:textColor="@color/nm_secondary"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_start_service"
            android:backgroundTint="@color/nm_success"
            android:textColor="@color/nm_background"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="32dp"/>

        <!-- ── Info footer ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_hint"
            android:textColor="@color/nm_secondary"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
</ScrollView>
